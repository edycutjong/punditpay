# ── Agent wallet (self-custodial — the agent's own keys, generated and held on THIS device) ──
# Get from: `npm run keygen` (prints a fresh BIP-39 phrase using node:crypto entropy)
# NEVER reuse a phrase that holds real funds. Only needed for --wallet=spark; --wallet=local needs nothing.
PUNDITPAY_SEED_PHRASE=

# ── Tip-jar (creator) wallet — the demo's second identity, receives the tips ──
# Get from: `npm run keygen` (run it twice: one phrase per identity)
TIPJAR_SEED_PHRASE=

# ── Spark settlement network ──
# TESTNET (default for the demo) | REGTEST | MAINNET (never required)
# Testnet funds: https://docs.spark.money (faucet) — tips are sats-denominated, zero-fee on Spark
SPARK_NETWORK=TESTNET

# ── Endpoints (local by default — the whole demo runs on your machine) ──
TIPJAR_URL=http://127.0.0.1:4021
TIPJAR_PORT=4021
CONSOLE_PORT=4020
